# Disable pnpm's automatic dependency check before `pnpm run`/`pnpm exec`.
# nx runs targets in parallel; each `pnpm exec tsc` otherwise triggers an
# implicit `pnpm install` that rewrites pnpm-lock.yaml, and the concurrent
# atomic renames collide on Windows with:
#   [EPERM] operation not permitted, rename 'pnpm-lock.yaml.<tmp>' -> 'pnpm-lock.yaml'
# We manage installs explicitly, so the pre-run verification is not needed here.
verify-deps-before-run=false
