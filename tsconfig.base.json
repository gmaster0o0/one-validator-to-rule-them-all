{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@one-validator-to-rule-them-all/shared-schema": [
        "./shared-schema/src/index.ts"
      ],
      "@one-validator-to-rule-them-all/shared-validation": [
        "./shared-validation/src/index.ts"
      ],
      "@one-validator-to-rule-them-all/schema": [
        "./shared/schema/src/index.ts"
      ],
      "@one-validator-to-rule-them-all/shared/schema": [
        "./shared/schema/src/index.ts"
      ],
      "@one-validator-to-rule-them-all/validation": [
        "./shared/validation/src/index.ts"
      ],
      "@one-validator-to-rule-them-all/testing": [
        "./shared/testing/src/index.ts"
      ],
      "@one-validator/ui-helm": [
        "./shared/ui-helm/src/index.ts"
      ],
      "@spartan-ng/helm/button": [
        "./shared/spartan-ng/button/src/index.ts"
      ],
      "@spartan-ng/helm/field": [
        "./shared/spartan-ng/field/src/index.ts"
      ],
      "@spartan-ng/helm/icon": [
        "./shared/spartan-ng/icon/src/index.ts"
      ],
      "@spartan-ng/helm/input": [
        "./shared/spartan-ng/input/src/index.ts"
      ],
      "@spartan-ng/helm/label": [
        "./shared/spartan-ng/label/src/index.ts"
      ],
      "@spartan-ng/helm/sonner": [
        "./shared/spartan-ng/sonner/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./shared/spartan-ng/utils/src/index.ts"
      ],
      "@spartan-ng/helm/separator": [
        "./shared/spartan-ng/separator/src/index.ts"
      ],
      "@spartan-ng/helm/card": [
        "./shared/spartan-ng/card/src/index.ts"
      ],
      "@spartan-ng/helm/alert": [
        "./shared/spartan-ng/alert/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
