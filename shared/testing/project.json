{
  "name": "testing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "shared/testing/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/shared/testing",
        "main": "shared/testing/src/index.ts",
        "tsConfig": "shared/testing/tsconfig.lib.json",
        "assets": ["shared/testing/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsc -p shared/testing/tsconfig.lib.json --noEmit"
      }
    }
  }
}
